{
  "name": "hackathon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "backend": "cd backend && ../.venv/bin/python3 start.py",
    "arq:worker": "cd backend && ../.venv/bin/arq job_scheduler.WorkerSettings",
    "arq:worker:dev": "cd backend && ../.venv/bin/python3 dev_arq_worker.py",
    "redis:start": "(nc -z localhost 6379 && echo 'Redis already running') || docker start redis 2>/dev/null || docker run -d --name redis -p 6379:6379 redis",
    "redis:stop": "docker stop redis 2>/dev/null; sudo systemctl stop redis-server 2>/dev/null; echo 'Redis stopped'",
    "backend:services": "concurrently \"npm run backend\" \"npm run arq:worker:dev\"",
    "dev": "next dev",
    "dev:all": "npm run redis:start && concurrently \"npm run dev\" \"npm run backend:services\"",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "security:audit": "npm audit --audit-level=high",
    "prestart": "node scripts/checkCriticalVulns.mjs",
    "prebuild": "node scripts/checkCriticalVulns.mjs"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.3.1",
    "@mendable/firecrawl-js": "^4.8.0",
    "@paper-design/shaders-react": "^0.0.63",
    "@react-three/fiber": "^9.4.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "2.76.1",
    "critters": "^0.0.23",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "katex": "^0.16.11",
    "lucide-react": "^0.548.0",
    "next": "^16.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.5.0",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^9.1.0",
    "react-textarea-autosize": "^8.5.9",
    "recharts": "^3.4.1",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "three": "^0.169.0",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.181.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.3",
    "concurrently": "^8.2.2",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "postcss": "^8.5.6",
    "supabase": "^2.63.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}