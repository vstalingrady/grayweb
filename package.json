{
  "name": "hackathon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "backend": "DATABASE_URL=\"sqlite:///./users.db\" cd backend && ../.venv/bin/python3 start.py",
    "mcp:build": "cd plans-habits-server && npm run build",
    "mcp:plans-habits-server": "node plans-habits-server/dist/index.js",
    "backend:with-mcp": "concurrently \"npm run backend\" \"npm run mcp:plans-habits-server\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:full": "node scripts/dev-full.js",
    "security:audit": "npm audit --audit-level=high",
    "prestart": "npm audit --audit-level=critical --json > /dev/null 2>&1 || (echo '❌ Critical security vulnerabilities detected! Run npm audit fix' && exit 1)",
    "prebuild": "npm audit --audit-level=critical --json > /dev/null 2>&1 || (echo '❌ Critical security vulnerabilities detected! Run npm audit fix' && exit 1)"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.3.1",
    "@mendable/firecrawl-js": "^4.8.0",
    "@paper-design/shaders-react": "^0.0.63",
    "@react-three/fiber": "^9.4.0",
    "@supabase/supabase-js": "2.76.1",
    "critters": "^0.0.23",
    "framer-motion": "^12.23.24",
    "katex": "^0.16.11",
    "lucide-react": "^0.548.0",
    "next": "^16.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^9.1.0",
    "recharts": "^3.4.1",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "three": "^0.169.0",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.181.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.8.32",
    "concurrently": "^8.2.2",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "postcss": "^8.5.6",
    "supabase": "^2.63.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}