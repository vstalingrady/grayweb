# =============================================================================
# GRAY APP CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values

# --- Database Configuration ---
LOCAL_DATABASE_URL=sqlite:///./backend/users.db
DB_MODE=local

# --- Supabase Configuration (AUTH ONLY) ---
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# --- AI Provider Configuration ---
# Default: OpenRouter, Pro: Gemini
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_ENABLED=true
OPENROUTER_LITE_MODEL=x-ai/grok-4.1-fast

GEMINI_API_KEY=AIzaSy-your-key-here
GEMINI_PRO_MODEL=models/gemini-3-pro-preview

# --- Google Calendar Integration (Optional) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here
# Random string >=16 chars for signing OAuth state
GOOGLE_STATE_SECRET=change_me_to_a_long_random_value
# Fernet key for encrypting refresh tokens (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
GOOGLE_TOKEN_ENCRYPTION_KEY=your_fernet_key
# Optional override (defaults to localhost in dev, gray.alignment.id in prod)
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google-calendar/callback

# --- Web Push Notifications (Optional) ---
# Generate with: npx web-push generate-vapid-keys
ENABLE_WEB_PUSH=true
VAPID_PUBLIC_KEY=your-public-key-here
VAPID_PRIVATE_KEY=your-private-key-here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key-here

# --- Application Behavior ---
ENVIRONMENT=production
NODE_ENV=production
ENABLE_FILE_SEARCH=true
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=https://your-domain.com

# --- Frontend URLs ---
NEXT_PUBLIC_SITE_URL=https://your-domain.com
BACKEND_API_URL=https://your-domain.com/api
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_DISABLE_API_PROXY=false

# --- Captcha (Cloudflare Turnstile) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAA-your-site-key
TURNSTILE_SECRET_KEY=0x4AAA-your-secret-key

# --- App Secret ---
# Generate with: openssl rand -hex 32
GRAY_APP_SECRET=your-64-char-hex-secret-here

# --- Payments (Midtrans) - Optional ---
MIDTRANS_SERVER_KEY=Mid-server-your-key
MIDTRANS_CLIENT_KEY=Mid-client-your-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-your-key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_MERCHANT_ID=your-merchant-id
