# =============================================================================
# GRAY APP CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values

# --- Database Configuration ---
LOCAL_DATABASE_URL=sqlite:///../data/users.db
DB_MODE=local

# --- Supabase Configuration (AUTH ONLY) ---
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# --- AI Provider Configuration ---
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_ENABLED=true
OPENROUTER_LITE_MODEL=x-ai/grok-4.1-fast
# Optional: override fast summary + image description models (vision-capable).
# OPENROUTER_SUMMARY_MODEL=google/gemini-3-flash-preview
# OPENROUTER_IMAGE_DESCRIPTION_MODEL=google/gemini-3-flash-preview
# Optional: explicit completion token cap. If unset, the backend won't apply an app-side cap
# (provider/model limits still apply).
# OPENROUTER_MAX_TOKENS=0

# --- Supermemory (Long-term Memory) ---
SUPERMEMORY_API_KEY=sm_your_supermemory_key_here
SUPERMEMORY_ENABLED=true
SUPERMEMORY_AUTO_RECALL=true
SUPERMEMORY_AUTO_CAPTURE=true
SUPERMEMORY_MAX_RECALL_RESULTS=4
SUPERMEMORY_PROFILE_FREQUENCY=50
SUPERMEMORY_CAPTURE_MODE=all
# Ops override for plan-tier forcing. Keep false so user memory toggle is respected.
GRAY_SUPERMEMORY_FORCE=false
GRAY_SUPERMEMORY_RECALL_EVERY_N=3
GRAY_SUPERMEMORY_MIN_PROMPT_CHARS=40
GRAY_HISTORY_TAIL_TURNS=8
GRAY_HISTORY_TAIL_FORCE=true
# Optional overrides
# SUPERMEMORY_BASE_URL=https://api.supermemory.ai
# SUPERMEMORY_CONTAINER_PREFIX=gray_user_
# SUPERMEMORY_DEBUG=false
# SUPERMEMORY_INTEGRITY_SECRET=generate_a_long_random_secret

# --- Google Calendar Integration (Optional) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here
# Random string >=16 chars for signing OAuth state
GOOGLE_STATE_SECRET=change_me_to_a_long_random_value
# Fernet key for encrypting refresh tokens (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
GOOGLE_TOKEN_ENCRYPTION_KEY=your_fernet_key
# Optional override (defaults to localhost in dev, gray.alignment.id in prod)
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google-calendar/callback

# --- Web Push Notifications (Optional) ---
# Generate with: npx web-push generate-vapid-keys
ENABLE_WEB_PUSH=true
VAPID_PUBLIC_KEY=your-public-key-here
VAPID_PRIVATE_KEY=your-private-key-here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key-here

# --- Application Behavior ---
ENVIRONMENT=production
NODE_ENV=production
ENABLE_FILE_SEARCH=true
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=https://your-domain.com
# Optional: expose uploaded files via /uploads (not recommended in production)
# ENABLE_PUBLIC_UPLOADS=false

# --- Frontend URLs ---
NEXT_PUBLIC_SITE_URL=https://gray.alignment.id
NEXT_PUBLIC_MAIN_SITE_URL=https://gray.alignment.id
NEXT_PUBLIC_PAYMENT_SITE_URL=https://payment.alignment.id
BACKEND_API_URL=https://gray.alignment.id/api
NEXT_PUBLIC_API_URL=https://api-gray.alignment.id
NEXT_PUBLIC_DISABLE_API_PROXY=false
AUTH_COOKIE_DOMAIN=.alignment.id
# Optional cookie verification secret for backend session-cookie auth:
# AUTH_COOKIE_SECRET=generate_a_long_random_secret
# Local dev/test only fallback (ignored outside explicit local environments):
# AUTH_COOKIE_LOCAL_SECRET=local_dev_only_secret

# --- Captcha (Cloudflare Turnstile) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAA-your-site-key
TURNSTILE_SECRET_KEY=0x4AAA-your-secret-key

# --- App Secret ---
# Generate with: openssl rand -hex 32
GRAY_APP_SECRET=your-64-char-hex-secret-here

# --- Discord Notifications (Optional) ---
# Used by `scripts/deploy_robust.sh` and `scripts/monitor_logs.py`
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_USER_ID=your-discord-user-id

# Optional: separate channels for alerts vs payments (falls back to DISCORD_WEBHOOK_URL)
# DISCORD_ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_PAYMENTS_WEBHOOK_URL=https://discord.com/api/webhooks/...
#
# Alert tuning
# DISCORD_ALERT_MIN_LEVEL=ERROR
# DISCORD_ALERT_EVENT_TYPES=db_slow_query,fallback_activation
# DISCORD_ALERT_COOLDOWN_SECONDS=120
# DISCORD_ALERT_MAX_PER_MINUTE=12
#
# Slow query threshold (ms) for DB instrumentation
# DB_SLOW_QUERY_MS=500

# --- Payments (Midtrans) - Optional ---
MIDTRANS_SERVER_KEY=Mid-server-your-key
MIDTRANS_CLIENT_KEY=Mid-client-your-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-your-key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_MERCHANT_ID=your-merchant-id

# --- Payments (Dodo) ---
DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_PAYMENTS_ENVIRONMENT=live_mode
DODO_PAYMENTS_WEBHOOK_KEY=whsec_your-webhook-signing-key
DODO_PAYMENTS_RETURN_URL=https://gray.alignment.id/payment/finish

# --- Payments (Gumroad) - Optional ---
# OAuth Application credentials (for "Sign in with Gumroad")

# Tiered Membership Configuration
# Product permalink (the part after gumroad.com/l/)

# Option IDs for each tier (found in tier URLs: ?option=...)
# Voyager: https://vstaln.gumroad.com/l/gray?option=lZ9QZXSGeVuLLYzGSzk7Bw==
# Pioneer: https://vstaln.gumroad.com/l/gray?option=1AKF6eGbTgVn1yq1m5YcXA==
