# This file contains environment variables for your project.
# The values below have been populated based on your input.

# --- Database Configuration (Dual Setup) ---
# REMOTE: Auth, users, sessions (Supabase PostgreSQL - backed up, critical)
REMOTE_DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres
# Or leave blank to auto-construct from SUPABASE_URL + SUPABASE_DB_PASSWORD

# LOCAL: Chat messages, plans, habits, calendar (SQLite - fast, local)
LOCAL_DATABASE_URL=sqlite:///./backend/users.db

# Legacy DATABASE_URL (falls back to LOCAL if not using dual setup)
DATABASE_URL=sqlite:///./backend/users.db

# Supabase DB Password (for auto-constructing REMOTE_DATABASE_URL)
SUPABASE_DB_PASSWORD=your-database-password


# --- Supabase Configuration ---
# Find these in your Supabase project's 'Settings' > 'API'.
SUPABASE_URL=https://your-project.supabase.co
# Use SUPABASE_KEY for backend (service role key for full access)
SUPABASE_KEY=your-service-role-key
# SUPABASE_ANON_KEY is for frontend (public, limited access)
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# These are redundant with the above, but kept for clarity if NEXT_PUBLIC_ is used elsewhere
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- AI Provider Configuration ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_DEFAULT_MODEL=gemini-flash-latest
GEMINI_LIGHT_MODEL=gemini-flash-lite-latest
GEMINI_PRO_MODEL=gemini-3-pro-preview
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-sonnet-20240229"

# OpenRouter Configuration
# Lite tier (Scout/Free) uses OpenRouter's free Grok model
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_LITE_MODEL=x-ai/grok-4.1-fast:free
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_SITE_NAME=Gray

# Lite tier provider: 'openrouter' uses Grok 4.1 Fast (free), 'gemini' uses Gemini Lite
LITE_TIER_PROVIDER=openrouter

# --- Google Calendar Integration ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://gray.alignment.id/callback

# --- Web Push Notifications (Optional) ---
ENABLE_WEB_PUSH="True"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# --- Application Behavior ---
ENVIRONMENT=development
NODE_ENV=development
ENABLE_FILE_SEARCH="true"
LOG_LEVEL="INFO"
CORS_ALLOW_ORIGINS=https://alignment.id/,https://gray.alignment.id,http://localhost:3001

# --- Frontend URLs ---
NEXT_PUBLIC_SITE_URL=http://localhost:3001
BACKEND_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DISABLE_API_PROXY=true

# --- Secrets and Keys ---
GUMROAD_WEBHOOK_SECRET="your-gumroad-webhook-secret"
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-webhook-secret
LEMONSQUEEZY_STORE_ID=alignment.lemonsqueezy.com
LEMONSQUEEZY_VOYAGER=1098953
LEMONSQUEEZY_PIONEER=1099908
GRAY_APP_SECRET=your-app-secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAACDfOE8EWig4fsrM
